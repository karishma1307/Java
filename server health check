class ServerHealthCheck extends Thread {
    public void run() {
        try {
            while (true) {
                System.out.println("Checking server status...");
                boolean serverUp = checkServer();
                if (serverUp) {
                    System.out.println("Server is UP");
                } else {
                    System.out.println("Server is DOWN");
                }
                Thread.sleep(5000);
            }
        } catch (InterruptedException e) {
            System.out.println("Health check interrupted");
        }
    }
    boolean checkServer() {
        return true;
    }
    public static void main(String args[]) {
        ServerHealthCheck shc = new ServerHealthCheck();
        shc.start();
    }
}